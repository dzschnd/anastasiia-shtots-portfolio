---
import { Image } from "astro:assets";
import heroImage from "../../assets/portfolio/4b262b3322df4cdbb9c8e6913ced65f5cd1396cb.png";
import newDashboardImage from "../../assets/portfolio/dubsmart-dashboard-new.png";
import oldDashboardImage from "../../assets/portfolio/dubsmart-dashboard-old.png";
import newDubbingImage from "../../assets/portfolio/dubsmart-new-design.png";
import oldDubbingImage from "../../assets/portfolio/dubsmart-old-design.png";
import FloatingBackButton from "../../components/FloatingBackButton.astro";
import PortfolioFooter from "../../components/portfolio/PortfolioFooter.astro";
import { getLocaleFromUrl, withLocale } from "../../i18n";
import { dubsmartPageContent } from "../../i18n/pages/projects/dubsmart";
import Layout from "../../layouts/Layout.astro";
const locale = getLocaleFromUrl(Astro.url);
const t = dubsmartPageContent[locale];
const meta = t.meta;
const projectMeta = t.projectMeta;
const contributions = t.contributions.items;
const taskFocus = t.contextAndTask.taskFocus;
const improvementCards = t.improvements.cards;
const oldDesignIssues = t.solutionOne.oldList;
const newDesignImprovements = t.solutionOne.newList;
const oldDashboardIssues = t.solutionTwo.oldList;
const newDashboardImprovements = t.solutionTwo.newList;
const dashboardCallouts = t.solutionTwo.callouts;
const featureIntegrationSteps = t.solutionThree.integrationSteps;
const featureIntegrationCards = t.solutionThree.cards;
const resultCards = t.result.cards;
---

<Layout title={t.pageTitle}>
	<div class="min-h-screen bg-[#1a1a1a] text-white">
		<main class="px-6 pb-16 pt-8 md:px-10 lg:px-16 lg:pb-24">
			<div class="mx-auto max-w-[960px]">
				<a
					href={withLocale("/", locale)}
					data-floating-back-trigger
					class="inline-flex items-center gap-2 text-sm text-white/48 transition hover:text-white/78"
				>
					<span>←</span>
					<span>{t.backToPortfolio}</span>
				</a>

				<section class="pt-8 md:pt-12">
					<h1 class="max-w-4xl text-[36px] font-semibold leading-tight tracking-[-0.04em] text-white">
						{t.heroTitle}
					</h1>
					<p class="mt-5 max-w-5xl text-lg leading-relaxed text-white/68">
						{t.heroIntro}
					</p>

					<div class="mt-6 flex flex-wrap items-center gap-3">
						{
							meta.map((item) => (
								<span class="rounded-full border border-[#08AAC8]/24 bg-[#062E58]/45 px-4 py-2 text-sm font-medium text-[#8FEFFF]">
									{item}
								</span>
							))
						}
					</div>

					<div class="mt-6 grid grid-cols-1 gap-5 rounded-[28px] border border-white/8 bg-white/[0.035] p-5 sm:grid-cols-2 lg:grid-cols-5">
						{
							projectMeta.map((item) => (
								<div class="min-w-0 text-left">
									<p class="text-xs font-medium uppercase tracking-[0.18em] text-white/38">
										{item.label}
									</p>
									{
										Array.isArray(item.value) ? (
											<div class="mt-2 flex flex-col gap-1 text-sm leading-5 text-white/78">
												{item.value.map((line) => (
													<p>{line}</p>
												))}
											</div>
										) : item.href ? (
											<a
												href={item.href}
												target="_blank"
												rel="noopener noreferrer"
												class="mt-2 inline-flex text-sm font-medium leading-6 text-[#8FEFFF] underline decoration-[#08AAC8]/45 underline-offset-4 transition hover:text-white hover:decoration-white/70"
											>
												{item.value}
											</a>
										) : (
											<p class="mt-2 text-sm leading-6 text-white/78">
												{item.value}
											</p>
										)
									}
								</div>
							))
						}
					</div>
				</section>

				<section class="mt-8 overflow-hidden rounded-[36px] border border-white/6 bg-[radial-gradient(circle_at_top,rgba(8,170,200,0.1),transparent_35%),#111111]">
					<Image
						src={heroImage}
						alt={t.heroImageAlt}
						class="h-full w-full object-cover"
					/>
				</section>

				<section class="mt-12 max-w-5xl">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.about.title}
					</h2>
					<p class="mt-5 max-w-4xl text-lg leading-relaxed text-white/68">
						{t.about.paragraphs[0]}
					</p>
					<p class="mt-4 max-w-4xl text-lg leading-relaxed text-white/68">
						{t.about.paragraphs[1]}
					</p>
				</section>

				<section class="mt-16">
					<div class="min-w-0 max-w-5xl">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.contributions.title}
						</h2>
						<p class="mt-4 w-full whitespace-normal break-normal text-lg leading-relaxed text-white/68">
							{t.contributions.intro}
						</p>
					</div>

					<div class="mt-8 grid items-stretch gap-4 md:grid-cols-2">
						{
							contributions.map((item) => (
								<article class="grid h-full rounded-[24px] border border-white/8 bg-white/[0.045] p-5 md:min-h-[306px] md:grid-rows-[auto_auto_1fr_auto] md:p-6">
									<div class="md:min-h-[92px]">
										<p class="text-sm font-medium tracking-[0.18em] text-[#08AAC8]/80">
											{item.number}
										</p>
										<h3 class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
											{item.title}
										</h3>
									</div>
									<p class="mt-2 text-base leading-6 text-white/68 md:min-h-[84px]">
										{item.description}
									</p>
									<div class="mt-3 border-t border-white/8 pt-5">
										<p class="text-xs font-medium uppercase tracking-[0.18em] text-white/38">
											{t.contributions.impactLabel}
										</p>
										<p class="mt-2 text-base leading-6 text-white/78">
											{item.impact}
										</p>
									</div>
									<div class="mt-6 self-end">
										<span class="inline-flex rounded-full border border-[#08AAC8]/24 bg-[#062E58]/45 px-3 py-1.5 text-xs font-medium text-[#8FEFFF]">
											{item.tag}
										</span>
									</div>
								</article>
							))
						}
					</div>
				</section>

				<section class="mt-16">
					<div class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
						<div class="min-w-0">
							<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
								{t.contextAndTask.title}
							</h2>
							<div class="mt-5 space-y-4 text-lg leading-relaxed text-white/68">
								<p>{t.contextAndTask.paragraphs[0]}</p>
								<p>{t.contextAndTask.paragraphs[1]}</p>
								<p>{t.contextAndTask.paragraphs[2]}</p>
							</div>
						</div>

						<aside class="rounded-[28px] border border-[#062E58]/70 bg-[linear-gradient(135deg,rgba(6,46,88,0.34),rgba(255,255,255,0.035))] p-6">
							<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#08AAC8]/80">
								{t.contextAndTask.keyTaskLabel}
							</p>
							<p class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
								{t.contextAndTask.keyTaskTitle}
							</p>
							<p class="mt-6 text-sm font-medium uppercase tracking-[0.18em] text-white/38">
								{t.contextAndTask.focusLabel}
							</p>
							<ul class="mt-4 space-y-3 text-base leading-6 text-white/72">
								{
									taskFocus.map((item) => (
										<li class="flex gap-3">
											<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#08AAC8]" />
											<span>{item}</span>
										</li>
									))
								}
							</ul>
						</aside>
					</div>

					<div class="mt-14">
						<h3 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.improvements.title}
						</h3>
						<p class="mt-5 max-w-4xl text-lg leading-relaxed text-white/68">
							{t.improvements.intro}
						</p>

						<div class="mt-8 grid items-stretch gap-4 md:grid-cols-2">
							{
								improvementCards.map((item) => (
									<article class="flex h-full flex-col rounded-[24px] border border-white/8 bg-white/[0.045] p-5 md:min-h-[190px] md:p-6">
										<p class="text-sm font-medium tracking-[0.18em] text-[#08AAC8]/80">
											{item.number}
										</p>
										<h4 class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
											{item.title}
										</h4>
										<p class="mt-3 text-base leading-6 text-white/68">
											{item.description}
										</p>
									</article>
								))
							}
						</div>
					</div>
				</section>

				<section class="mt-16">
					<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#08AAC8]/80">
						{t.solutionOne.eyebrow}
					</p>
					<h2 class="mt-4 max-w-4xl text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.solutionOne.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/68">
						<p>{t.solutionOne.paragraphs[0]}</p>
						<p>{t.solutionOne.paragraphs[1]}</p>
					</div>

					<div class="mt-8 grid gap-4 lg:grid-cols-2">
						<figure class="overflow-hidden rounded-[28px] border border-white/8 bg-white/[0.035]">
							<figcaption class="border-b border-white/8 px-5 py-4 text-sm font-medium uppercase tracking-[0.18em] text-white/42">
								{t.solutionOne.imageCaptions.old}
							</figcaption>
							<button
								type="button"
								data-lightbox-src={oldDubbingImage.src}
								data-lightbox-caption={t.solutionOne.imageCaptions.old}
								class="block w-full cursor-zoom-in text-left"
								aria-label={t.solutionOne.imageAria.old}
							>
								<Image
									src={oldDubbingImage}
									alt={t.solutionOne.imageAlt.old}
									class="block h-auto w-full object-contain"
								/>
							</button>
						</figure>
						<figure class="overflow-hidden rounded-[28px] border border-white/8 bg-white/[0.035]">
							<figcaption class="border-b border-white/8 px-5 py-4 text-sm font-medium uppercase tracking-[0.18em] text-white/42">
								{t.solutionOne.imageCaptions.new}
							</figcaption>
							<button
								type="button"
								data-lightbox-src={newDubbingImage.src}
								data-lightbox-caption={t.solutionOne.imageCaptions.new}
								class="block w-full cursor-zoom-in text-left"
								aria-label={t.solutionOne.imageAria.new}
							>
								<Image
									src={newDubbingImage}
									alt={t.solutionOne.imageAlt.new}
									class="block h-auto w-full object-contain"
								/>
							</button>
						</figure>
					</div>

					<div class="mt-6 grid gap-8 lg:grid-cols-2">
						<div>
							<h3 class="text-xl font-semibold leading-tight tracking-[-0.03em] text-white">
								{t.solutionOne.oldListTitle}
							</h3>
							<ul class="mt-4 space-y-3 text-base leading-6 text-white/68">
								{
									oldDesignIssues.map((item) => (
										<li class="flex gap-3">
											<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-white/32" />
											<span>{item}</span>
										</li>
									))
								}
							</ul>
						</div>
						<div>
							<h3 class="text-xl font-semibold leading-tight tracking-[-0.03em] text-white">
								{t.solutionOne.newListTitle}
							</h3>
							<ul class="mt-4 space-y-3 text-base leading-6 text-white/68">
								{
									newDesignImprovements.map((item) => (
										<li class="flex gap-3">
											<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#08AAC8]" />
											<span>{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
				</section>

				<section class="mt-16">
					<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#08AAC8]/80">
						{t.solutionTwo.eyebrow}
					</p>
					<h2 class="mt-4 max-w-4xl text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.solutionTwo.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/68">
						<p>{t.solutionTwo.paragraphs[0]}</p>
						<p>{t.solutionTwo.paragraphs[1]}</p>
					</div>

					<div class="mt-8 grid gap-4 lg:grid-cols-2">
						<figure class="overflow-hidden rounded-[28px] border border-white/8 bg-white/[0.035]">
							<figcaption class="border-b border-white/8 px-5 py-4 text-sm font-medium uppercase tracking-[0.18em] text-white/42">
								{t.solutionTwo.imageCaptions.old}
							</figcaption>
							<button
								type="button"
								data-lightbox-src={oldDashboardImage.src}
								data-lightbox-caption={t.solutionTwo.imageCaptions.old}
								class="block w-full cursor-zoom-in text-left"
								aria-label={t.solutionTwo.imageAria.old}
							>
								<Image
									src={oldDashboardImage}
									alt={t.solutionTwo.imageAlt.old}
									class="block h-auto w-full object-contain"
								/>
							</button>
						</figure>
						<figure class="overflow-hidden rounded-[28px] border border-white/8 bg-white/[0.035]">
							<figcaption class="border-b border-white/8 px-5 py-4 text-sm font-medium uppercase tracking-[0.18em] text-white/42">
								{t.solutionTwo.imageCaptions.new}
							</figcaption>
							<button
								type="button"
								data-lightbox-src={newDashboardImage.src}
								data-lightbox-caption={t.solutionTwo.imageCaptions.new}
								class="block w-full cursor-zoom-in text-left"
								aria-label={t.solutionTwo.imageAria.new}
							>
								<Image
									src={newDashboardImage}
									alt={t.solutionTwo.imageAlt.new}
									class="block h-auto w-full object-contain"
								/>
							</button>
						</figure>
					</div>

					<div class="mt-6 grid gap-8 lg:grid-cols-2">
						<div>
							<h3 class="text-xl font-semibold leading-tight tracking-[-0.03em] text-white">
								{t.solutionTwo.oldListTitle}
							</h3>
							<ul class="mt-4 space-y-3 text-base leading-6 text-white/68">
								{
									oldDashboardIssues.map((item) => (
										<li class="flex gap-3">
											<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-white/32" />
											<span>{item}</span>
										</li>
									))
								}
							</ul>
						</div>
						<div>
							<h3 class="text-xl font-semibold leading-tight tracking-[-0.03em] text-white">
								{t.solutionTwo.newListTitle}
							</h3>
							<ul class="mt-4 space-y-3 text-base leading-6 text-white/68">
								{
									newDashboardImprovements.map((item) => (
										<li class="flex gap-3">
											<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#08AAC8]" />
											<span>{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>

					<div class="mt-8 grid items-stretch gap-4 md:grid-cols-2">
						{
							dashboardCallouts.map((item) => (
								<article class="relative flex h-full min-h-[220px] overflow-hidden rounded-[24px] border border-[#08AAC8]/18 bg-[linear-gradient(135deg,rgba(6,46,88,0.34),rgba(255,255,255,0.045)_42%,rgba(255,255,255,0.025))] p-5 md:p-6">
									<div class="absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,rgba(8,170,200,0.72),rgba(255,255,255,0.08))]" />
									<div class="absolute right-0 top-0 h-24 w-24 rounded-full bg-[#08AAC8]/10 blur-2xl" />
									<div class="relative flex h-full flex-col">
										<p class="text-sm font-medium tracking-[0.18em] text-[#08AAC8]">
											{item.number}
										</p>
										<h3 class="mt-5 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
											{item.title}
										</h3>
										<p class="mt-4 text-base leading-6 text-white/74">
											{item.description}
										</p>
									</div>
								</article>
							))
						}
					</div>
				</section>

				<section class="mt-16">
					<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#08AAC8]/80">
						{t.solutionThree.eyebrow}
					</p>
					<h2 class="mt-4 max-w-4xl text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.solutionThree.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/68">
						<p>{t.solutionThree.paragraphs[0]}</p>
						<p>{t.solutionThree.paragraphs[1]}</p>
					</div>

					<figure class="mt-8 overflow-hidden rounded-[28px] border border-white/8 bg-[radial-gradient(circle_at_top,rgba(8,170,200,0.1),transparent_42%),rgba(255,255,255,0.035)]">
						<figcaption class="border-b border-white/8 px-5 py-4 text-sm font-medium uppercase tracking-[0.18em] text-white/42">
							{t.solutionThree.integrationCaption}
						</figcaption>
						<div class="overflow-x-auto px-5 py-8">
							<div class="flex min-w-[760px] items-center gap-3">
								{
									featureIntegrationSteps.map((step, index) => (
										<>
											<div class="flex min-h-[92px] flex-1 items-center justify-center rounded-[22px] border border-[#08AAC8]/18 bg-[#062E58]/30 px-4 text-center">
												<p class="text-base font-semibold leading-6 tracking-[-0.02em] text-white">
													{step}
												</p>
											</div>
											{index < featureIntegrationSteps.length - 1 && (
												<span class="shrink-0 text-xl text-[#08AAC8]/76">→</span>
											)}
										</>
									))
								}
							</div>
						</div>
					</figure>
					<p class="mt-3 text-sm leading-6 text-white/46">
						{t.solutionThree.integrationNote}
					</p>

					<div class="mt-8 grid gap-4 lg:grid-cols-3">
						{
							featureIntegrationCards.map((item) => (
								<article class="flex h-full flex-col rounded-[22px] border border-white/8 bg-white/[0.045] p-5">
									<p class="text-sm font-medium tracking-[0.18em] text-[#08AAC8]/80">
										{item.number}
									</p>
									<h3 class="mt-4 text-xl font-semibold leading-tight tracking-[-0.03em] text-white">
										{item.title}
									</h3>
									<p class="mt-3 text-base leading-6 text-white/68">
										{item.description}
									</p>
								</article>
							))
						}
					</div>
				</section>

				<section class="mt-16 overflow-hidden rounded-[32px] border border-[#062E58]/70 bg-[radial-gradient(circle_at_top_left,rgba(8,170,200,0.13),transparent_38%),rgba(255,255,255,0.035)] p-6 md:p-8">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.result.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/72">
						<p>{t.result.paragraphs[0]}</p>
						<p>{t.result.paragraphs[1]}</p>
						<p>{t.result.paragraphs[2]}</p>
					</div>

					<div class="mt-8 grid items-stretch gap-4 md:grid-cols-2">
						{
							resultCards.map((item) => (
								<article class="relative h-full overflow-hidden rounded-[24px] border border-white/8 bg-[#111111]/70 p-5 md:min-h-[210px] md:p-6">
									<div class="absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,rgba(8,170,200,0.7),rgba(255,255,255,0.06))]" />
									<p class="text-sm font-medium tracking-[0.18em] text-[#08AAC8]/86">
										{item.number}
									</p>
									<h3 class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
										{item.title}
									</h3>
									<p class="mt-3 text-base leading-6 text-white/70">
										{item.description}
									</p>
								</article>
							))
						}
					</div>
				</section>
			</div>
			<FloatingBackButton />
		</main>
		<PortfolioFooter />

		<div
			id="dubbing-lightbox"
			class="fixed inset-0 z-50 hidden items-center justify-center bg-black/82 p-4 backdrop-blur-sm"
			aria-hidden="true"
		>
			<button
				type="button"
				data-lightbox-close
				class="absolute right-5 top-5 flex size-10 items-center justify-center rounded-full border border-white/20 bg-black/50 text-xl leading-none text-white/80 transition-all duration-200 hover:scale-105 hover:border-white/40 hover:bg-white/10 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
				aria-label={t.lightbox.closeAria}
			>
				×
			</button>
			<button
				type="button"
				data-lightbox-backdrop
				class="absolute inset-0 cursor-default"
				aria-label={t.lightbox.closeAria}
			/>
			<figure class="relative z-10 max-h-[92vh] w-full max-w-6xl">
				<img
					data-lightbox-image
					src=""
					alt=""
					class="mx-auto block max-h-[86vh] w-full object-contain"
				/>
				<figcaption
					data-lightbox-caption
					class="mt-3 text-center text-sm font-medium uppercase tracking-[0.18em] text-white/62"
				>
				</figcaption>
			</figure>
		</div>
	</div>
</Layout>

<script>
	const lightbox = document.getElementById("dubbing-lightbox");
	const lightboxImage = lightbox?.querySelector("[data-lightbox-image]");
	const lightboxCaption = lightbox?.querySelector("[data-lightbox-caption]");
	const openButtons = document.querySelectorAll("[data-lightbox-src]");
	const closeButtons = document.querySelectorAll(
		"[data-lightbox-close], [data-lightbox-backdrop]",
	);

	function openLightbox(src, caption) {
		if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
			return;
		}

		lightboxImage.src = src;
		lightboxImage.alt = caption;
		if (lightboxCaption) {
			lightboxCaption.textContent = caption;
		}
		lightbox.classList.remove("hidden");
		lightbox.classList.add("flex");
		lightbox.setAttribute("aria-hidden", "false");
		document.documentElement.style.overflow = "hidden";
	}

	function closeLightbox() {
		if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
			return;
		}

		lightbox.classList.add("hidden");
		lightbox.classList.remove("flex");
		lightbox.setAttribute("aria-hidden", "true");
		lightboxImage.src = "";
		document.documentElement.style.overflow = "";
	}

	openButtons.forEach((button) => {
		button.addEventListener("click", () => {
			if (!(button instanceof HTMLElement)) {
				return;
			}

			openLightbox(
				button.dataset.lightboxSrc ?? "",
				button.dataset.lightboxCaption ?? "",
			);
		});
	});

	closeButtons.forEach((button) => {
		button.addEventListener("click", closeLightbox);
	});

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeLightbox();
		}
	});
</script>
