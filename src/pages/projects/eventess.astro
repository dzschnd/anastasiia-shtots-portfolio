---
import { Image } from "astro:assets";
import heroImage from "../../assets/portfolio/eventess-cover.png";
import accountDraftsImage from "../../assets/portfolio/eventess-account-drafts.png";
import accountProfileImage from "../../assets/portfolio/eventess-account-profile.png";
import constructorImage from "../../assets/portfolio/eventess-constructor.png";
import visualDirectionImage from "../../assets/portfolio/eventess-visual-direction.png";
import FloatingBackButton from "../../components/FloatingBackButton.astro";
import PortfolioFooter from "../../components/portfolio/PortfolioFooter.astro";
import { getLocaleFromUrl, withLocale } from "../../i18n";
import { eventessPageContent } from "../../i18n/pages/projects/eventess";
import Layout from "../../layouts/Layout.astro";
const locale = getLocaleFromUrl(Astro.url);
const t = eventessPageContent[locale];
const meta = t.meta;
const projectMeta = t.projectMeta;
const contributions = t.contributions.items;
const taskFocus = t.contextAndTask.taskFocus;
const userFlowSteps = t.userFlow.steps;
const productPriorities = t.priorities.cards;
const results = t.result.cards;
---

<Layout title={t.pageTitle}>
	<div class="min-h-screen bg-[#1a1a1a] text-white">
		<main class="px-6 pb-16 pt-8 md:px-10 lg:px-16 lg:pb-24">
			<div class="mx-auto max-w-[960px]">
				<a
					href={withLocale("/", locale)}
					data-floating-back-trigger
					class="inline-flex items-center gap-2 text-sm text-white/48 transition hover:text-white/78"
				>
					<span>←</span>
					<span>{t.backToPortfolio}</span>
				</a>

				<section class="pt-8 md:pt-12">
					<h1 class="max-w-4xl text-[36px] font-semibold leading-tight tracking-[-0.04em] text-white">
						{t.heroTitle}
					</h1>
					<p class="mt-5 max-w-5xl text-lg leading-relaxed text-white/68">
						{t.heroIntro}
					</p>

					<div class="mt-6 flex flex-wrap items-center gap-3">
						{
							meta.map((item) => (
								<span class="rounded-full border border-[#F09A9C]/18 bg-[#F09A9C]/8 px-4 py-2 text-sm font-medium text-[#F7C5C6]">
									{item}
								</span>
							))
						}
					</div>

					<div class="mt-6 grid grid-cols-1 gap-5 rounded-[28px] border border-white/8 bg-white/[0.035] p-5 sm:grid-cols-2 lg:grid-cols-5">
						{
							projectMeta.map((item) => (
								<div class="min-w-0 text-left">
									<p class="text-xs font-medium uppercase tracking-[0.18em] text-white/38">
										{item.label}
									</p>
									{
										Array.isArray(item.value) ? (
											<div class="mt-2 flex flex-col gap-1 text-sm leading-5 text-white/78">
												{item.value.map((line) => (
													<p>{line}</p>
												))}
											</div>
										) : item.href ? (
											<a
												href={item.href}
												target="_blank"
												rel="noopener noreferrer"
												class="mt-2 inline-flex text-sm font-medium leading-6 text-[#F7C5C6] underline decoration-[#F09A9C]/45 underline-offset-4 transition hover:text-white hover:decoration-white/70"
											>
												{item.value}
											</a>
										) : (
											<p class="mt-2 text-sm leading-6 text-white/78">
												{item.value}
											</p>
										)
									}
								</div>
							))
						}
					</div>
				</section>

				<section class="mt-8 overflow-hidden rounded-[36px] border border-white/6 bg-[#111111]">
					<Image
						src={heroImage}
						alt={t.heroImageAlt}
						class="block h-auto w-full object-contain"
					/>
				</section>

				<section class="mt-16 grid gap-6 lg:grid-cols-[1fr_0.95fr] lg:items-start">
					<div class="min-w-0">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.about.title}
						</h2>
						<div class="mt-5 space-y-4 text-lg leading-relaxed text-white/68">
							<p>{t.about.paragraphs[0]}</p>
							<p>{t.about.paragraphs[1]}</p>
						</div>
					</div>

					<aside class="rounded-[28px] border border-white/8 bg-white/[0.045] p-6">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.role.title}
						</h2>
						<div class="mt-5 space-y-4 text-lg leading-relaxed text-white/68">
							<p>{t.role.paragraphs[0]}</p>
							<p>{t.role.paragraphs[1]}</p>
						</div>
					</aside>
				</section>

				<section class="mt-16">
					<div class="max-w-4xl">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.contributions.title}
						</h2>
						<p class="mt-4 text-lg leading-relaxed text-white/68">
							{t.contributions.intro}
						</p>
					</div>

					<div class="mt-8 grid items-stretch gap-4 md:grid-cols-2">
						{
							contributions.map((item) => (
								<article class="flex h-full flex-col rounded-[24px] border border-white/8 bg-[linear-gradient(135deg,rgba(240,154,156,0.055),rgba(255,255,255,0.035))] p-5 md:min-h-[240px] md:p-6">
									<p class="text-sm font-medium tracking-[0.18em] text-[#F09A9C]/80">
										{item.number}
									</p>
									<h3 class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
										{item.title}
									</h3>
									<p class="mt-3 text-base leading-6 text-white/68">
										{item.description}
									</p>
									<div class="mt-auto pt-5">
										<span class="inline-flex rounded-full border border-[#F09A9C]/18 bg-[#F09A9C]/8 px-3 py-1.5 text-xs font-medium text-[#F7C5C6]">
											{item.tag}
										</span>
									</div>
								</article>
							))
						}
					</div>
				</section>

				<section class="mt-16 grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
					<div class="min-w-0">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.contextAndTask.title}
						</h2>
						<div class="mt-5 space-y-4 text-lg leading-relaxed text-white/68">
							<p>{t.contextAndTask.paragraphs[0]}</p>
							<p>{t.contextAndTask.paragraphs[1]}</p>
							<p>{t.contextAndTask.paragraphs[2]}</p>
						</div>
					</div>

					<aside class="rounded-[28px] border border-[#F09A9C]/16 bg-[linear-gradient(135deg,rgba(240,154,156,0.09),rgba(255,255,255,0.035))] p-6">
						<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#F09A9C]/80">
							{t.contextAndTask.keyTaskLabel}
						</p>
						<p class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
							{t.contextAndTask.keyTaskTitle}
						</p>
						<ul class="mt-6 space-y-3 text-base leading-6 text-white/72">
							{
								taskFocus.map((item) => (
									<li class="flex gap-3">
										<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#F09A9C]" />
										<span>{item}</span>
									</li>
								))
							}
						</ul>
					</aside>
				</section>

				<section class="mt-16">
					<div class="max-w-4xl">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.userFlow.title}
						</h2>
						<div class="mt-5 space-y-4 text-lg leading-relaxed text-white/68">
							<p>{t.userFlow.paragraphs[0]}</p>
							<p>{t.userFlow.paragraphs[1]}</p>
						</div>
					</div>

					<div class="mt-8 overflow-hidden rounded-[28px] border border-white/8 bg-[radial-gradient(circle_at_top,rgba(240,154,156,0.09),transparent_42%),rgba(255,255,255,0.035)] p-5 md:p-6">
						<div class="grid w-full grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
							{
								userFlowSteps.map((step, index) => (
									<div class="relative flex min-h-[88px] flex-col justify-between rounded-[18px] border border-white/8 bg-[#111111]/72 p-4">
										<p class="text-xs font-medium tracking-[0.18em] text-[#F09A9C]/80">
											{String(index + 1).padStart(2, "0")}
										</p>
										<p class="mt-3 text-base font-semibold leading-6 tracking-[-0.02em] text-white">
											{step}
										</p>
										{index < userFlowSteps.length - 1 && (
											<span class="absolute right-3 top-3 text-sm text-[#F09A9C]/52">
												→
											</span>
										)}
									</div>
								))
							}
						</div>
					</div>
					<p class="mt-3 text-sm leading-6 text-white/46">
						{t.userFlow.note}
					</p>
				</section>

				<section class="mt-16">
					<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#F09A9C]/80">
						{t.brandingSolution.eyebrow}
					</p>
					<h2 class="mt-4 max-w-4xl text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.brandingSolution.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/68">
						<p>{t.brandingSolution.paragraphs[0]}</p>
						<p>{t.brandingSolution.paragraphs[1]}</p>
					</div>

					<figure class="mt-8 overflow-hidden rounded-[28px] border border-white/8 bg-[radial-gradient(circle_at_top,rgba(240,154,156,0.09),transparent_42%),rgba(255,255,255,0.035)]">
						<figcaption class="border-b border-white/8 px-5 py-4 text-sm font-medium uppercase tracking-[0.18em] text-white/42">
							{t.brandingSolution.figureCaption}
						</figcaption>
						<button
							type="button"
							data-lightbox-src={visualDirectionImage.src}
							data-lightbox-caption={t.brandingSolution.figureLightboxCaption}
							class="block w-full cursor-zoom-in text-left"
							aria-label={t.brandingSolution.figureAria}
						>
							<Image
								src={visualDirectionImage}
								alt={t.brandingSolution.figureAlt}
								class="block h-auto w-full object-contain"
							/>
						</button>
					</figure>
				</section>

				<section class="mt-16">
					<div class="max-w-4xl">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
							{t.priorities.title}
						</h2>
						<p class="mt-4 text-lg leading-relaxed text-white/68">
							{t.priorities.intro}
						</p>
					</div>

					<div class="mt-8 grid items-stretch gap-4 md:grid-cols-2">
						{
							productPriorities.map((item) => (
								<article class="flex h-full flex-col rounded-[24px] border border-white/8 bg-[linear-gradient(135deg,rgba(240,154,156,0.055),rgba(255,255,255,0.035))] p-5 md:min-h-[220px] md:p-6">
									<p class="text-sm font-medium tracking-[0.18em] text-[#F09A9C]/80">
										{item.number}
									</p>
									<h3 class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.03em] text-white">
										{item.title}
									</h3>
									<p class="mt-3 text-base leading-6 text-white/68">
										{item.description}
									</p>
								</article>
							))
						}
					</div>
				</section>

				<section class="mt-16">
					<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#F09A9C]/80">
						{t.constructorSolution.eyebrow}
					</p>
					<h2 class="mt-4 max-w-4xl text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.constructorSolution.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/68">
						<p>{t.constructorSolution.paragraphs[0]}</p>
						<p>{t.constructorSolution.paragraphs[1]}</p>
					</div>

					<figure class="mt-8 overflow-hidden rounded-[28px] border border-white/8 bg-[radial-gradient(circle_at_top,rgba(240,154,156,0.09),transparent_42%),rgba(255,255,255,0.035)]">
						<button
							type="button"
							data-lightbox-src={constructorImage.src}
							data-lightbox-caption={t.constructorSolution.figureLightboxCaption}
							class="block w-full cursor-zoom-in text-left"
							aria-label={t.constructorSolution.figureAria}
						>
							<Image
								src={constructorImage}
								alt={t.constructorSolution.figureAlt}
								class="block h-auto w-full object-contain"
							/>
						</button>
					</figure>
					<p class="mt-3 text-sm leading-6 text-white/46">
						{t.constructorSolution.note}
					</p>
				</section>

				<section class="mt-16">
					<p class="text-sm font-medium uppercase tracking-[0.18em] text-[#F09A9C]/80">
						{t.accountSolution.eyebrow}
					</p>
					<h2 class="mt-4 max-w-4xl text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.accountSolution.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/68">
						<p>{t.accountSolution.paragraphs[0]}</p>
						<p>{t.accountSolution.paragraphs[1]}</p>
						<p>{t.accountSolution.paragraphs[2]}</p>
					</div>

					<figure class="mt-8 overflow-hidden rounded-[28px] border border-white/8 bg-[radial-gradient(circle_at_top,rgba(240,154,156,0.09),transparent_42%),rgba(255,255,255,0.035)]">
						<figcaption class="border-b border-white/8 px-5 py-4 text-sm font-medium uppercase tracking-[0.18em] text-white/42">
							{t.accountSolution.figureTitle}
						</figcaption>
						<div class="space-y-4 p-4 md:p-5">
							<figure class="overflow-hidden rounded-[22px] border border-white/8 bg-[#111111]/72">
								<figcaption class="border-b border-white/8 px-4 py-3 text-xs font-medium uppercase tracking-[0.16em] text-[#F7C5C6]/70">
									{t.accountSolution.draftsCaption}
								</figcaption>
								<button
									type="button"
									class="block w-full cursor-zoom-in overflow-hidden bg-white"
									data-lightbox-src={accountDraftsImage.src}
									data-lightbox-caption={t.accountSolution.draftsLightboxCaption}
									aria-label={t.accountSolution.draftsAria}
								>
									<Image
										src={accountDraftsImage}
										alt={t.accountSolution.draftsAlt}
										class="block h-auto w-full object-contain"
										loading="lazy"
									/>
								</button>
							</figure>

							<figure class="overflow-hidden rounded-[22px] border border-white/8 bg-[#111111]/72">
								<figcaption class="border-b border-white/8 px-4 py-3 text-xs font-medium uppercase tracking-[0.16em] text-[#F7C5C6]/70">
									{t.accountSolution.profileCaption}
								</figcaption>
								<button
									type="button"
									class="block w-full cursor-zoom-in overflow-hidden bg-white"
									data-lightbox-src={accountProfileImage.src}
									data-lightbox-caption={t.accountSolution.profileLightboxCaption}
									aria-label={t.accountSolution.profileAria}
								>
									<Image
										src={accountProfileImage}
										alt={t.accountSolution.profileAlt}
										class="block h-auto w-full object-contain"
										loading="lazy"
									/>
								</button>
							</figure>
						</div>
					</figure>
					<p class="mt-3 text-sm leading-6 text-white/46">
						{t.accountSolution.note}
					</p>
				</section>

				<section class="mt-16 rounded-[32px] border border-[#F09A9C]/14 bg-[radial-gradient(circle_at_top_left,rgba(240,154,156,0.14),transparent_34%),rgba(255,255,255,0.035)] p-5 md:p-8">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
						{t.result.title}
					</h2>
					<div class="mt-5 max-w-4xl space-y-4 text-lg leading-relaxed text-white/68">
						<p>{t.result.paragraphs[0]}</p>
						<p>{t.result.paragraphs[1]}</p>
					</div>

					<div class="mt-8 grid gap-4 md:grid-cols-2">
						{
							results.map((item) => (
								<article class="flex h-full flex-col rounded-[24px] border border-white/8 bg-[#111111]/68 p-5">
									<p class="text-sm font-semibold text-[#F09A9C]/85">{item.number}</p>
									<h3 class="mt-4 text-xl font-semibold tracking-[-0.03em] text-white">
										{item.title}
									</h3>
									<p class="mt-3 text-base leading-7 text-white/62">
										{item.description}
									</p>
								</article>
							))
						}
					</div>
				</section>
			</div>
			<FloatingBackButton />
		</main>
		<PortfolioFooter />

		<div
			id="eventess-lightbox"
			class="fixed inset-0 z-50 hidden items-center justify-center bg-black/82 p-4 backdrop-blur-sm"
			aria-hidden="true"
		>
			<button
				type="button"
				data-lightbox-close
				class="absolute right-5 top-5 flex size-10 items-center justify-center rounded-full border border-white/20 bg-black/50 text-xl leading-none text-white/80 transition-all duration-200 hover:scale-105 hover:border-white/40 hover:bg-white/10 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
				aria-label={t.lightbox.closeAria}
			>
				×
			</button>
			<button
				type="button"
				data-lightbox-backdrop
				class="absolute inset-0 cursor-default"
				aria-label={t.lightbox.closeAria}
			/>
			<figure class="relative z-10 max-h-[92vh] w-full max-w-6xl">
				<img
					data-lightbox-image
					src=""
					alt=""
					class="mx-auto block max-h-[86vh] w-full object-contain"
				/>
				<figcaption
					data-lightbox-caption
					class="mt-3 text-center text-sm font-medium uppercase tracking-[0.18em] text-white/62"
				>
				</figcaption>
			</figure>
		</div>
	</div>
</Layout>

<script>
	const lightbox = document.getElementById("eventess-lightbox");
	const lightboxImage = lightbox?.querySelector("[data-lightbox-image]");
	const lightboxCaption = lightbox?.querySelector("[data-lightbox-caption]");
	const openButtons = document.querySelectorAll("[data-lightbox-src]");
	const closeButtons = document.querySelectorAll(
		"[data-lightbox-close], [data-lightbox-backdrop]",
	);

	function openLightbox(src, caption) {
		if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
			return;
		}

		lightboxImage.src = src;
		lightboxImage.alt = caption;
		if (lightboxCaption) {
			lightboxCaption.textContent = caption;
		}
		lightbox.classList.remove("hidden");
		lightbox.classList.add("flex");
		lightbox.setAttribute("aria-hidden", "false");
		document.documentElement.style.overflow = "hidden";
	}

	function closeLightbox() {
		if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
			return;
		}

		lightbox.classList.add("hidden");
		lightbox.classList.remove("flex");
		lightbox.setAttribute("aria-hidden", "true");
		lightboxImage.src = "";
		document.documentElement.style.overflow = "";
	}

	openButtons.forEach((button) => {
		button.addEventListener("click", () => {
			if (!(button instanceof HTMLElement)) {
				return;
			}

			openLightbox(
				button.dataset.lightboxSrc ?? "",
				button.dataset.lightboxCaption ?? "",
			);
		});
	});

	closeButtons.forEach((button) => {
		button.addEventListener("click", closeLightbox);
	});

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeLightbox();
		}
	});
</script>
