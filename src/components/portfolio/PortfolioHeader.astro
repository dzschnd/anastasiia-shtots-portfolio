---
import { Image } from "astro:assets";
import profileImage from "../../assets/portfolio/afc6c6ff25807132cfdfc963daaed0cc14a23859.png";
import {
	BehanceIcon,
	DprofileIcon,
	LinkedinIcon,
	ResumeIcon,
	TelegramIcon,
} from "../icons/SocialIcons";
import SocialChip from "./SocialChip";

const socialLinks = [
	{
		label: "CV",
		href: "https://drive.google.com/file/d/1Jpm0slr8dWpkdwDEUMCQ43pudED7BZF_/view?usp=sharing",
		Icon: ResumeIcon,
	},
	{
		label: "Telegram",
		href: "https://t.me/NastyaSchtoz",
		Icon: TelegramIcon,
	},
	{
		label: "LinkedIn",
		href: "https://www.linkedin.com/in/anastasiia-shtots/",
		Icon: LinkedinIcon,
	},
	{
		label: "Behance",
		href: "https://www.behance.net/nastyas1",
		Icon: BehanceIcon,
	},
	{
		label: "Dprofile",
		href: "https://dprofile.ru/anastasiia.shtots",
		Icon: DprofileIcon,
	},
];
---

<header class="relative overflow-hidden px-6 pb-12 pt-8 md:px-10 md:pb-14 md:pt-12 lg:px-16 lg:pt-14">
	<div class="relative mx-auto max-w-[880px]">
		<!-- <div class="absolute right-0 top-0 inline-flex rounded-full border border-white/10 bg-white/4 p-1 shadow-[0_0_24px_rgba(255,120,233,0.08)] backdrop-blur"> -->
		<!-- 	<button -->
		<!-- 		type="button" -->
		<!-- 		class="rounded-full bg-white px-3.5 py-2 text-xs font-semibold tracking-[0.18em] text-[#111111]" -->
		<!-- 	> -->
		<!-- 		RU -->
		<!-- 	</button> -->
		<!-- 	<button -->
		<!-- 		type="button" -->
		<!-- 		class="rounded-full px-3.5 py-2 text-xs font-semibold tracking-[0.18em] text-white/45" -->
		<!-- 	> -->
		<!-- 		EN -->
		<!-- 	</button> -->
		<!-- </div> -->

		<div class="flex flex-col gap-7 pt-14 md:grid md:grid-cols-[112px_minmax(0,1fr)] md:items-start md:gap-8 md:pt-2 lg:grid-cols-[124px_minmax(0,1fr)]">
			<div class="relative shrink-0">
				<div class="relative size-28 overflow-hidden rounded-full ring-1 ring-white/10 md:size-28 lg:size-31">
					<Image
						src={profileImage}
						alt="Анастасия Штоц"
						class="h-full w-full object-cover object-center"
					/>
				</div>
			</div>

			<div class="min-w-0 pr-0 md:pr-32">
				<div class="mb-2 flex flex-col gap-1.5">
					<h1 class="text-[28px] font-semibold tracking-[-0.02em] text-white md:text-[36px]">
						Анастасия Штоц
					</h1>
				</div>

				<p class="max-w-[620px] text-base leading-7 text-white/68 md:text-[17px]">
					Product / UX/UI дизайнер с опытом 3 года в AI, SaaS и
					web-продуктах. Проектирую понятные интерфейсы для сложных
					сервисов — от сценариев и дашбордов до дизайн-систем.
				</p>

				<div class="mt-6 flex max-w-[620px] flex-wrap items-center gap-2.5">
					{socialLinks.map((link) => (
						<SocialChip label={link.label} href={link.href} Icon={link.Icon} />
					))}
				</div>
			</div>
		</div>
	</div>
</header>
