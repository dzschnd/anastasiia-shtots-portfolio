---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { getLocaleFromUrl, withLocale } from "../../i18n";
import { coreMessages } from "../../i18n/messages";

interface Props {
	title: string;
	description: string;
	tags: string[];
	image: ImageMetadata;
	gradient: string;
	href?: string;
}

const { title, description, tags, image, gradient, href = "#" } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const localizedHref = href.startsWith("/") ? withLocale(href, locale) : href;
---

<a
	href={localizedHref}
	class="group overflow-hidden rounded-[24px] border border-zinc-700 bg-[#111111] transition duration-500 hover:border-zinc-600"
	style={`background-image: ${gradient}`}
>
	<div class="relative aspect-[1.8/1] overflow-hidden">
		<Image
			src={image}
			alt={title}
			class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.06]"
		/>
	</div>

	<div class="bg-[linear-gradient(180deg,rgba(10,10,10,0.96)_0%,rgba(3,3,3,1)_100%)] px-5 pb-5 pt-5 md:px-6 md:pb-6">
		<div class="flex flex-wrap gap-2">
			{tags.map((tag) => (
				<span class="rounded-full border border-white/6 bg-white/4 px-3 py-1 text-[11px] font-medium tracking-[0.03em] text-white/42">
					{tag}
				</span>
			))}
		</div>

		<h2 class="mt-4 text-[22px] font-semibold tracking-[-0.03em] text-white">
			{title}
		</h2>
		<p class="mt-2 text-sm leading-6 text-white/46 md:text-[15px]">
			{description}
		</p>

		<div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-white/62 transition duration-300 group-hover:text-[#ff92ee]">
			<span>{coreMessages[locale].viewCase}</span>
			<svg fill="none" viewBox="0 0 24 24" class="size-4">
				<path
					d="M5.75 12h12.5M13.25 6.75 18.5 12l-5.25 5.25"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="1.7"
				/>
			</svg>
		</div>
	</div>
</a>
