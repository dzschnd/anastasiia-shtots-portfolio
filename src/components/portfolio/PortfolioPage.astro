---
import { Image } from "astro:assets";
import caseOneImage from "../../assets/portfolio/4b262b3322df4cdbb9c8e6913ced65f5cd1396cb.png";
import doctorHelperImage from "../../assets/portfolio/doctor-helper-cover.png";
import eventessImage from "../../assets/portfolio/eventess-cover.png";
import lollygothImage from "../../assets/portfolio/lollygoth-cover.png";
import noLimitsImage from "../../assets/portfolio/no-limits-cover.png";
import CaseCard from "./CaseCard.astro";
import PortfolioFooter from "./PortfolioFooter.astro";
import PortfolioHeader from "./PortfolioHeader.astro";
import { getLocaleFromUrl } from "../../i18n";
import { coreMessages } from "../../i18n/messages";
import { homePageContent } from "../../i18n/pages/home";

const locale = getLocaleFromUrl(Astro.url);
const content = homePageContent[locale];

const caseStudies = content.caseStudies.map((study) => ({
	...study,
	image:
		study.href === "/projects/dubsmart"
			? caseOneImage
			: study.href === "/projects/eventess"
				? eventessImage
				: doctorHelperImage,
}));

const visualProjects = content.visualProjects.map((project) => ({
	...project,
	image: project.title === "Lollygoth" ? lollygothImage : noLimitsImage,
}));
---

<div class="min-h-screen bg-[#1a1a1a] text-white">
	<PortfolioHeader />

	<main class="px-6 pb-14 md:px-10 md:pb-16 lg:px-16 lg:pb-20">
		<div class="mx-auto mb-8 max-w-[880px]">
			<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
				{coreMessages[locale].cases}
			</h2>
		</div>

		<div class="mx-auto grid max-w-[880px] grid-cols-1 gap-6">
			{caseStudies.map((study) => (
				<CaseCard {...study} />
			))}
		</div>

		<section class="mx-auto mt-16 max-w-[880px]">
			<div class="mb-8 max-w-2xl">
				<h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
					{coreMessages[locale].notOnlyInterfaces}
				</h2>
				<p class="mt-3 text-base leading-7 text-white/52 md:text-lg">
					{coreMessages[locale].visualProjectsText}
				</p>
			</div>

			<div class="grid gap-5 md:grid-cols-2">
				{visualProjects.map((project) => (
					<a
						href={project.href}
						target="_blank"
						rel="noopener noreferrer"
						class="group overflow-hidden rounded-[26px] border border-zinc-700 bg-[#101010] transition duration-500 hover:border-zinc-600"
					>
						<div class="relative aspect-[1.34/1] overflow-hidden bg-black">
							<Image
								src={project.image}
								alt={project.coverAlt}
								class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.06]"
								loading="lazy"
							/>
							<div class="absolute inset-0 border border-white/10"></div>
							<div class="absolute right-5 top-5 rounded-full border border-white/16 bg-black/24 px-3 py-1 text-xs font-medium text-white/72 backdrop-blur">
								{project.behanceLabel}
							</div>
						</div>

						<div class="p-5 md:p-6">
							<div class="flex flex-wrap gap-2">
								{project.tags.map((tag) => (
									<span class={`rounded-full border px-3 py-1 text-[11px] font-medium tracking-[0.03em] ${project.tagClass}`}>
										{tag}
									</span>
								))}
							</div>

							<h3 class="mt-4 text-2xl font-semibold tracking-[-0.04em] text-white">
								{project.title}
							</h3>
							<p class="mt-3 text-sm leading-6 text-white/52">
								{project.description}
							</p>

							<span class="mt-5 inline-flex items-center rounded-full border border-white/12 bg-white/5 px-4 py-2 text-sm font-medium text-white/70 transition duration-300 hover:border-white/22 hover:bg-white/9 hover:text-white">
								{coreMessages[locale].viewCaseBehance}
							</span>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>

	<PortfolioFooter />
</div>
